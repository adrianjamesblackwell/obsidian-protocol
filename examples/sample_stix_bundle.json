    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--03aea00a-51c4-41f3-a3a9-d02dbe564f62",
      "created": "2026-06-27T11:49:03.762Z",
      "modified": "2026-06-27T11:49:03.762Z",
      "name": "Apache Path Traversal - Encoded Double-Dot Sequence",
      "description": "Encode edilmiş path traversal deseninin /cgi-bin/ ScriptAlias path'i üzerinden kullanılması. WARDEN/Sigma kuralı: detection/sigma/apache_path_traversal_cve_2021_41773.yml",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[network-traffic:extensions.http-request-ext.request_value MATCHES '.*%2e%2e/.*cgi-bin.*']",
      "valid_from": "2026-06-27T11:49:03.762Z"
    },
    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--03f63342-0111-49cc-96d4-4dfe6b6fec55",
      "created": "2026-06-27T11:49:03.762Z",
      "modified": "2026-06-27T11:49:03.762Z",
      "name": "PwnKit pkexec argc=0 Exploitation",
      "description": "pkexec'in argümansız (argc=0) çağrılması ve GCONV_PATH environment variable manipülasyonu. WARDEN/Sigma kuralı: detection/sigma/pwnkit_cve_2021_4034.yml",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[process:name = 'pkexec' AND process:command_line = '' AND process:environment_variables.GCONV_PATH MATCHES '.*']",
      "valid_from": "2026-06-27T11:49:03.762Z"
    },
    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--9b7e1d6f-2312-4851-b76c-066dcd0f5e2e",
      "created": "2026-06-27T11:49:03.762Z",
      "modified": "2026-06-27T11:49:03.762Z",
      "name": "AndroxGh0st Botnet - .env Scanning Pattern",
      "description": "FBI/CISA AA24-016A danışma belgesinde tanımlanan AndroxGh0st botnet IOC deseni (.env dosya tarama, PHPUnit eval-stdin.php exploitation denemesi).",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[url:value MATCHES '.*\\\\.env$' OR url:value MATCHES '.*eval-stdin\\\\.php$']",
      "valid_from": "2026-06-27T11:49:03.762Z"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--9828e722-8189-42a8-b3cc-c45b6a4df125",
      "created": "2026-06-27T11:49:03.762Z",
      "modified": "2026-06-27T11:49:03.762Z",
      "name": "AndroxGh0st",
      "description": "Python tabanlı botnet, ilk olarak Aralık 2022'de Lacework tarafından tespit edildi. Laravel .env dosyalarını tarayarak AWS/Microsoft 365/SendGrid/Twilio kimlik bilgilerini çalmaya çalışır. CVE-2021-41773, CVE-2017-9841 ve CVE-2018-15133'ü kullanır. Kaynak: CISA/FBI AA24-016A.",
      "is_family": true,
      "malware_types": [
        "bot"
      ]
    },
