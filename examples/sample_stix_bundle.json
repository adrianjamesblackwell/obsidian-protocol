    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--67b795c9-1427-4000-bceb-b9d832e762ad",
      "created": "2026-06-28T13:08:06.270Z",
      "modified": "2026-06-28T13:08:06.270Z",
      "name": "Apache Path Traversal - Encoded Double-Dot Sequence",
      "description": "An encoded path traversal pattern used via the /cgi-bin/ ScriptAlias path. WARDEN/Sigma rule: detection/sigma/apache_path_traversal_cve_2021_41773.yml",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[network-traffic:extensions.http-request-ext.request_value MATCHES '.*%2e%2e/.*cgi-bin.*']",
      "valid_from": "2026-06-28T13:08:06.270Z"
    },
    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--3a4c71c9-aa07-4658-8238-555efa46bddf",
      "created": "2026-06-28T13:08:06.270Z",
      "modified": "2026-06-28T13:08:06.270Z",
      "name": "PwnKit pkexec argc=0 Exploitation",
      "description": "pkexec invoked with no arguments (argc=0) combined with GCONV_PATH environment variable manipulation. WARDEN/Sigma rule: detection/sigma/pwnkit_cve_2021_4034.yml",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[process:name = 'pkexec' AND process:command_line = '' AND process:environment_variables.GCONV_PATH MATCHES '.*']",
      "valid_from": "2026-06-28T13:08:06.270Z"
    },
    {
      "type": "indicator",
      "spec_version": "2.1",
      "id": "indicator--74c7e300-0d64-423a-9e51-38deb6893911",
      "created": "2026-06-28T13:08:06.270Z",
      "modified": "2026-06-28T13:08:06.270Z",
      "name": "AndroxGh0st Botnet - .env Scanning Pattern",
      "description": "The AndroxGh0st botnet IOC pattern described in the FBI/CISA AA24-016A advisory (.env file scanning, PHPUnit eval-stdin.php exploitation attempt).",
      "indicator_types": [
        "malicious-activity"
      ],
      "pattern_type": "stix",
      "pattern_version": "2.1",
      "pattern": "[url:value MATCHES '.*\\\\.env$' OR url:value MATCHES '.*eval-stdin\\\\.php$']",
      "valid_from": "2026-06-28T13:08:06.270Z"
    },
    {
      "type": "malware",
      "spec_version": "2.1",
      "id": "malware--810f9799-4caa-49ac-a408-941262a68b5e",
      "created": "2026-06-28T13:08:06.270Z",
      "modified": "2026-06-28T13:08:06.270Z",
      "name": "AndroxGh0st",
      "description": "A Python-based botnet, first identified by Lacework in December 2022. Scans Laravel .env files attempting to steal AWS/Microsoft 365/SendGrid/Twilio credentials. Uses CVE-2021-41773, CVE-2017-9841, and CVE-2018-15133. Source: CISA/FBI AA24-016A.",
      "is_family": true,
      "malware_types": [
        "bot"
      ]
    },
